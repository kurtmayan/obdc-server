// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Stores {
  id               String            @id @default(cuid(2))
  code             String?
  name             String
  region           String
  province         String
  municipality     String
  barangay         String
  exactAddress     String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  devices          Devices[]
  storeSyncRecords StoreSyncRecord[]
  contactInfo      String?
}

model Devices {
  id           String   @id @default(cuid(2))
  model        String
  serialNumber String
  store        Stores   @relation(fields: [storesId], references: [id])
  storesId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AttendanceRecord {
  id                String          @id @default(cuid(2))
  userId            String
  employeeName      String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  logType           Int
  logDate           DateTime
  storeSyncRecordID String
  storeSyncRecords  StoreSyncRecord @relation(fields: [storeSyncRecordID], references: [id])
}

model StoreSyncRecord {
  id               String             @id @default(cuid(2))
  syncDate         DateTime           @default(now())
  store            Stores             @relation(fields: [storesId], references: [id])
  storesId         String
  attendanceRecord AttendanceRecord[]
}

enum Role {
  HR
  SUPERADMIN
  MP
}

model Users {
  id           String    @id @default(cuid(2))
  email        String    @unique
  password     String
  firstName    String
  middleName   String
  lastName     String
  role         Role
  otp          String?
  otpExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
