// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Division {
  rtm_operations
  head_office
  warehouse
}

enum Cluster {
  mindanao_1
  mindanao_2
  visayas_2
  visayas_1
  ncr_north_east
  ncr_south_calapa
  south_luzon
  north_central_luzon
  head_office
  warehouse
}

enum Status {
  active
  inactive
}

model Stores {
  id               String            @id @default(cuid(2))
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  devices          Devices[]
  storeSyncRecords StoreSyncRecord[]

  code          String
  name          String
  division      Division
  location      String
  cluster       Cluster
  contactPerson String
  contactNumber String?
  status        Status
}

model Devices {
  id           String   @id @default(cuid(2))
  model        String
  serialNumber String
  store        Stores   @relation(fields: [storesId], references: [id])
  storesId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AttendanceRecord {
  id                String          @id @default(cuid(2))
  userId            String
  employeeName      String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  logType           Int
  logDate           DateTime
  storeSyncRecordID String
  storeSyncRecords  StoreSyncRecord @relation(fields: [storeSyncRecordID], references: [id])
}

model StoreSyncRecord {
  id               String             @id @default(cuid(2))
  syncDate         DateTime           @default(now())
  store            Stores             @relation(fields: [storesId], references: [id])
  storesId         String
  attendanceRecord AttendanceRecord[]
}

enum Role {
  HR
  SUPERADMIN
  MP
}

enum UserStatus {
  ACTIVE
  PENDING
}

model Users {
  id                     String     @id @default(cuid(2))
  email                  String     @unique
  password               String?
  firstName              String
  middleName             String
  lastName               String
  role                   Role
  otp                    String?
  otpExpiresAt           DateTime?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  contactNumber          String?
  status                 UserStatus @default(PENDING)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}
