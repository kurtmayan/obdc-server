// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Division {
  rtm_operations
  head_office
  warehouse
}

enum Cluster {
  mindanao_1
  mindanao_2
  visayas_2
  visayas_1
  ncr_north_east
  ncr_south_calapa
  south_luzon
  north_central_luzon
  head_office
  warehouse
}

enum Status {
  active
  inactive
}

model Stores {
  id               String            @id @default(cuid(2))
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  devices          Devices[]
  storeSyncRecords StoreSyncRecord[]

  code          String?
  name          String
  division      Division
  location      String
  cluster       Cluster
  contactPerson String?
  contactNumber String?
  status        Status
}

model Devices {
  id           String   @id @default(cuid(2))
  model        String
  serialNumber String
  store        Stores   @relation(fields: [storesId], references: [id], onDelete: Cascade)
  storesId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AttendanceRecord {
  id                String          @id @default(cuid(2))
  userId            String
  employeeName      String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  logType           Int
  logDate           DateTime
  storeSyncRecordID String
  storeSyncRecords  StoreSyncRecord @relation(fields: [storeSyncRecordID], references: [id], onDelete: Cascade)
}

enum SyncStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

model StoreSyncRecord {
  id       String   @id @default(cuid(2))
  syncDate DateTime @default(now())

  status          SyncStatus @default(PENDING)
  totalRecords    Int        @default(0)
  insertedRecords Int        @default(0)
  failedRecords   Int        @default(0)
  errorMessage    String?

  startedAt   DateTime?
  completedAt DateTime?

  store            Stores                 @relation(fields: [storesId], references: [id], onDelete: Cascade)
  storesId         String
  attendanceRecord AttendanceRecord[]
  chunks           StoreSyncRecordChunk[]
}

model StoreSyncRecordChunk {
  id                String          @id @default(cuid(2))
  storeSyncRecordID String
  storeSyncRecord   StoreSyncRecord @relation(fields: [storeSyncRecordID], references: [id], onDelete: Cascade)

  chunkIndex Int
  status     SyncStatus @default(PENDING)

  totalRecords    Int @default(0)
  insertedRecords Int @default(0)
  failedRecords   Int @default(0)

  payload Json

  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeSyncRecordID, chunkIndex])
  @@index([status])
  @@index([storeSyncRecordID, status])
}

enum Role {
  HR
  SUPERADMIN
  MP
}

enum UserStatus {
  ACTIVE
  PENDING
}

model Users {
  id                     String       @id @default(cuid(2))
  email                  String       @unique
  password               String?
  firstName              String
  middleName             String
  lastName               String
  role                   Role
  otp                    String?
  otpExpiresAt           DateTime?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  contactNumber          String?
  status                 UserStatus   @default(PENDING)
  lastPasswordUpdate     DateTime     @default(now())
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  auditTrails            AuditTrail[]
}

model SyncStatistics {
  id                 String   @id @default(cuid(2))
  totalSyncedSuccess Int      @default(0)
  syncDate           DateTime @unique @default(dbgenerated("CURRENT_DATE")) @db.Date
}

model AuditTrail {
  id          String   @id @default(cuid(2))
  userId      String?
  user        Users?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail   String?
  action      String
  method      String
  endpoint    String
  statusCode  Int?
  description String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userEmail])
  @@index([action])
  @@index([createdAt])
}
